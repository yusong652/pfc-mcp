{
  "name": "liner",
  "dimension": "3D",
  "full_name": "Liner Structural-Element Properties",
  "description": "Property keywords for the 3DEC liner structural element. Assign with 'structure liner create ...', set elastic behavior with 'structure liner cmodel ...', then set these with 'structure liner property <keyword> <value> [range ...]'.",
