{
  "name": "pile",
  "dimension": "3D",
  "full_name": "Pile Structural-Element Properties",
  "description": "Property keywords for the 3DEC pile structural element. Assign with 'structure pile create ...', set elastic behavior with 'structure pile cmodel ...', then set these with 'structure pile property <keyword> <value> [range ...]'.",
  "primary_commands": [
    "structure pile create",
    "structure pile cmodel",
    "structure pile property",
    "structure pile list"
  ],
  "property_groups": [
    {
      "name": "Properties",
      "description": "'structure pile property' keywords (2D-only keywords omitted; 3DEC is 3D).",
      "properties": [
        {
          "keyword": "cross-sectional-area",
          "description": "",
          "type": "FLT"
        },
        {
          "keyword": "density",
          "description": "mass density",
          "type": "FLT"
        },
        {
          "keyword": "direction-y",
          "description": "direction-y vector whose projection onto the element cross-section defines the \\(y\\) -axis of the element coordinate system",
          "type": "VEC"
        },
        {
          "keyword": "moi-y",
          "description": "moment of inertia with respect to element \\(y\\) -axis",
          "type": "FLT"
        },
        {
          "keyword": "moi-z",
          "description": "moment of inertia with respect to element \\(z\\) -axis",
          "type": "FLT"
        },
        {
          "keyword": "plastic-moment",
          "description": "plastic moment capacity in Y and Z",
          "type": "FLT"
        },
        {
          "keyword": "plastic-moment-y",
          "description": "plastic moment capacity in Y",
          "type": "FLT"
        },
        {
          "keyword": "plastic-moment-z",
          "description": "plastic moment capacity in Z",
          "type": "FLT"
        },
        {
          "keyword": "plastic-shear",
          "description": "plastic shear capacity in Y and Z",
          "type": "FLT"
        },
        {
          "keyword": "plastic-shear-y",
          "description": "plastic shear capacity in Y",
          "type": "FLT"
        },
        {
          "keyword": "plastic-shear-z",
          "description": "plastic shear capacity in Z",
          "type": "FLT"
        },
        {
          "keyword": "shear-coefficient-y",
          "description": "shear coefficient for transverse shear deformation in the \\(y\\) -direction (Timoshenko beam only)",
          "type": "FLT"
        },
        {
          "keyword": "shear-coefficient-z",
          "description": "shear coefficient for transverse shear deformation in the \\(z\\) -direction (Timoshenko beam only)",
          "type": "FLT"
        },
        {
          "keyword": "spacing",
          "description": "spacing ( 2D only)",
          "type": "FLT"
        },
        {
          "keyword": "thermal-expansion",
          "description": "thermal-expansion coefficient",
          "type": "FLT"
        },
        {
          "keyword": "torsion-constant",
          "description": "torsion constant",
          "type": "FLT"
        },
        {
          "keyword": "coupling-cohesion-normal",
          "description": "normal coupling spring cohesion per unit length",
          "type": "FLT"
        },
        {
          "keyword": "coupling-cohesion-shear",
          "description": "shear coupling spring cohesion per unit length",
          "type": "FLT"
        },
        {
          "keyword": "coupling-friction-normal",
          "description": "normal coupling spring friction angle",
          "type": "FLT"
        },
        {
          "keyword": "coupling-friction-shear",
          "description": "shear coupling spring friction angle",
          "type": "FLT"
        },
        {
          "keyword": "coupling-gap-normal",
          "description": "normal coupling spring gap-use flag",
          "type": "BOOL"
        },
        {
          "keyword": "coupling-stiffness-normal",
          "description": "normal coupling spring stiffness",
          "type": "FLT"
        },
        {
          "keyword": "coupling-stiffness-shear",
          "description": "shear coupling spring stiffness",
          "type": "FLT"
        },
        {
          "keyword": "perimeter",
          "description": "exposed perimeter",
          "type": "FLT"
        },
        {
          "keyword": "slide",
          "description": "large-strain sliding flag",
          "type": "BOOL"
        },
        {
          "keyword": "slide-tolerance",
          "description": "large-strain sliding tolerance",
          "type": "FLT"
        },
        {
          "keyword": "coupling-cohesion-table",
          "description": "name of the table relating cohesion of shear coupling spring to relative shear displacement",
          "type": "STR"
        },
        {
          "keyword": "coupling-confining-flag",
          "description": "flag to activate incremental confining stress logic",
          "type": "BOOL"
        },
        {
          "keyword": "coupling-confining-table",
          "description": "name of the table relating effective confining stress factor to deviatoric stress",
          "type": "STR"
        },
        {
          "keyword": "coupling-friction-table",
          "description": "name of the table relating friction angle of shear coupling spring to relative shear displacement",
          "type": "STR"
        },
        {
          "keyword": "rockbolt-flag",
          "description": "flag to activate rockbolt logic",
          "type": "BOOL"
        },
        {
          "keyword": "tensile-failure-strain",
          "description": "tensile failure strain (non-dimensional, only active if rockbolt-flag is on )",
          "type": "FLT"
        },
        {
          "keyword": "yield-compression",
          "description": "axial compressive yield strength (force unit, only active if rockbolt-flag is on )",
          "type": "FLT"
        },
        {
          "keyword": "yield-tension",
          "description": "axial tensile yield strength (force unit, only active if rockbolt-flag is on )",
          "type": "FLT"
        }
      ]
    }
  ],
  "source": "https://docs.itascacg.com/itasca900/common/sel/doc/manual/sel_manual/piles/commands/cmd_structure.pile.property.html"
}
