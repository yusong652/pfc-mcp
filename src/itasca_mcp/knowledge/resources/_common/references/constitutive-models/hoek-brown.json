    {
      "name": "Properties",
      "description": "Material properties for the 'hoek-brown' zone constitutive model. Assign the model with 'zone cmodel assign hoek-brown [range ...]', then set these with 'zone property <keyword> <value> [range cmodel-name hoek-brown]'.",
