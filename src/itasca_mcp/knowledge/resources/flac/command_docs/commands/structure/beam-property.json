{
  "category": "structure",
  "search_keywords": [
    "beam",
    "property",
    "structure"
  ],
  "description": "Assigns properties to beam elements in the range. The properties consist of constitutive model properties, and additional properties of beam-type elements. The constitutive model property names are primary keywords, but are not included in the list above. The following properties are available, with the constitutive model properties listed first.",
  "python_sdk_alternative": {
    "available": false
  },
  "versions": {
    "6.0": {
      "command": "structure beam property",
      "syntax": "structure beam property keyword <range>",
      "description": "Assigns a property to elements in the range. The following properties are available.",
      "keywords": [
        {
          "name": "density",
          "syntax": "density f",
          "description": "density (needed if dynamic mode or gravity are active), ρ"
        },
        {
          "name": "youngs",
          "syntax": "youngs f",
          "description": "Young’s modulus, E"
        },
        {
          "name": "poisson",
          "syntax": "poisson f",
          "description": "Poisson’s ratio, ν"
        },
        {
          "name": "plastic-moment",
          "syntax": "plastic-moment f",
          "description": "plastic moment capacity, MP"
        },
        {
          "name": "thermal-expansion",
          "syntax": "thermal-expansion f",
          "description": "thermal expansion coefficient, αt"
        },
        {
          "name": "cross-sectional-area",
          "syntax": "cross-sectional-area f",
          "description": "cross-sectional area, A"
        },
        {
          "name": "moi-y",
          "syntax": "moi-y f",
          "description": "second moment with respect to local y-axis, Iy"
        },
        {
          "name": "moi-z",
          "syntax": "moi-z f",
          "description": "second moment with respect to local z-axis, Iz"
        },
        {
          "name": "moi-polar",
          "syntax": "moi-polar f",
          "description": "polar moment of inertia, J"
        },
        {
          "name": "direction-y",
          "syntax": "direction-y v",
          "description": "y-axis vector components (Yx, Yy, Yz) whose projection onto the element cross-section defines the y-axis of the element system"
        }
      ],
      "legacy_documentation": {
        "availability_verified": true,
        "source": "official FLAC3D 6.0 command indexes",
        "source_urls": [
          "https://docs.itascacg.com/pfc600/flac3d/sel/doc/manual/sel_manual/beams/commands/cmd_structure.beam.property.html#structure.beam.property"
        ],
        "syntax_basis": "official FLAC3D 6.0 detailed command page",
        "target_version": "6.0"
      }
    },
