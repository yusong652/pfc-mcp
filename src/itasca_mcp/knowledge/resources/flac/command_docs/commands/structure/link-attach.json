          "syntax": "y [linkattachoptions]",
          "description": "translational y-direction, also degree-of-freedom 2"
        },
        {
          "name": "z",
          "syntax": "z [linkattachoptions]",
          "description": "translational z-direction, also degree-of-freedom 3"
        },
        {
