{
  "category": "zone",
  "search_keywords": [
    "results",
    "zone"
  ],
  "description": "Controls if and what values are saved from zones in an exported results file. See the model results export command. By default, zones values are active . The values being exported by default are stresses , groups and displacements .",
  "python_sdk_alternative": {
    "available": false
  },
  "versions": {
    "6.0": {
      "command": "zone results",
      "syntax": "zone results",
      "keywords": [
        {
          "name": "active",
          "syntax": "active b",
          "description": "Controls if any zone values will be exported."
        },
        {
          "name": "attach",
          "syntax": "attach b",
          "description": "all attach condition information"
        },
        {
          "name": "displacements",
          "syntax": "displacements b",
          "description": "displacement vectors at gridpoints"
        },
        {
          "name": "extra",
          "syntax": "extra b",
          "description": "all extra variables at zones and gridpoints"
        },
        {
          "name": "forces",
          "syntax": "forces b",
          "description": "unbalanced force information at gridpoints, including the last local force ratio."
        },
        {
          "name": "groups",
          "syntax": "groups b",
          "description": "Group assignments to zones, faces, and gridpoints"
        },
        {
          "name": "interfaces",
          "syntax": "interfaces b",
          "description": "all interface information"
        },
        {
          "name": "model-fluid",
          "syntax": "model-fluid b",
          "description": "all fluid constitutive model information"
        },
        {
          "name": "model-mechanical",
          "syntax": "model-mechanical b",
          "description": "all mechanical constitutive model information"
        },
        {
          "name": "model-thermal",
          "syntax": "model-thermal b",
          "description": "all thermal constitutive model information"
        },
        {
          "name": "pore-pressure",
          "syntax": "pore-pressure b",
          "description": "pore pressure values at gridpoints"
        },
        {
          "name": "pore-pressure-range",
          "syntax": "range <range>",
          "description": "Specifies a range used to filter which zones are included in a results file export. This range is saved and restored as part of the model state. Note that this facility is still somewhat experimental, and there may be issues if zone-dependent features like attach, apply, etc. are also included in a results export."
        },
        {
          "name": "saturation",
          "syntax": "saturation b",
          "description": "saturation values at gridpoints"
        },
        {
          "name": "stresses",
          "syntax": "stresses b",
          "description": "average stresses in each zone. Note that the internal tetra stresses are never exported."
        },
        {
          "name": "temperatures",
          "syntax": "temperatures b",
          "description": "temperature values at gridpoints"
        },
        {
          "name": "velocities",
          "syntax": "velocities b",
          "description": "velocity vectors at gridpoints"
        },
        {
          "name": "water",
          "syntax": "water b",
          "description": "all water table information."
        }
      ],
      "legacy_documentation": {
        "availability_verified": true,
        "source": "official FLAC3D 6.0 command indexes",
