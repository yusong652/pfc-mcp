{
  "module": "itasca.interfaceelementarray",
  "description": "Array interface for FLAC interface elements.",
  "import_statement": "import itasca",
  "source_url": "https://docs.itascacg.com/itasca900/common/docproject/source/manual/scripting/python/doc/itasca.interfaceelementarray.html",
  "functions": [
    {
      "name": "area",
      "signature": "itasca.interfaceelementarray.area() -> array float{nelement}",
      "description": "(3D only) Get array with element areas.",
      "returns": {
        "type": "array float{nelement}"
      }
    },
    {
      "name": "in_group",
      "signature": "itasca.interfaceelementarray.in_group(group_name: str, slot=\"default\") -> array bool{nelement}",
      "description": "Return interface element group membership as a Boolean array.",
      "parameters": [
        {
          "name": "group_name",
          "type": "str",
          "required": true
        },
        {
          "name": "slot",
          "required": false
        }
      ],
      "returns": {
        "type": "array bool{nelement}"
      }
    },
    {
      "name": "normal",
      "signature": "itasca.interfaceelementarray.normal() -> array DVect{nelement}",
      "description": "Get array with element normal.",
      "returns": {
        "type": "array DVect{nelement}"
      }
    },
    {
      "name": "of_interface",
      "signature": "itasca.interfaceelementarray.of_interface(string name) -> array bool{nelement}",
      "description": "Return interface node of interface with 'name' as boolean array.",
      "parameters": [
        {
          "name": "string name",
          "required": true
        }
      ],
      "returns": {
        "type": "array bool{nelement}"
      }
    },
    {
      "name": "set_group",
      "signature": "itasca.interfaceelementarray.set_group(membership: array bool{interface}, group_name: str, slot=\"default\") -> None",
      "description": "Set interface element group from an array. Where membership True set the corresponding interface element to be a member of group group_name in the given slot.",
      "parameters": [
        {
          "name": "membership",
          "type": "array bool{interface}",
          "required": true
        },
        {
          "name": "group_name",
          "type": "str",
          "required": true
        },
        {
          "name": "slot",
          "required": false
        }
      ],
      "returns": {
        "type": "None"
      }
    }
  ]
}
