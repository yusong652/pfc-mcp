      "syntax": "range <range-element> [...]"
    },
    {
      "keyword": "legend",
      "description": "Show/configure the item legend.",
      "syntax": "legend <sub-keyword> [<value>]"
    },
    {
      "keyword": "transparency",
      "description": "Set item transparency (0 opaque .. 100 fully transparent).",
      "syntax": "transparency <0-100>"
    }
