{
  "model": "springnetwork",
  "full_name": "Spring Network Model",
  "search_keywords": [
    "contact",
    "model",
    "network",
    "spring",
    "springnetwork"
  ],
  "description": "The spring network model can be used to simulate unbonded and bonded systems. The bonded formulation is based on the Rigid Body Spring Network (RBSN) lattice model introduced by [Bolander1998a] based on the work of [Kawai1978] , and the subsequent work of [Asahina2015] .",
  "typical_applications": [
    "Rigid-body-spring-network rock fracture",
    "Quasi-brittle failure with tensile/cohesion tables",
    "Lattice-type fracture modeling",
    "Heterogeneous strength via property tables"
  ],
